PORT=4000
NODE_ENV=development

# Render / cloud: use one URL (Internal URL when API and DB are both on Render).
# DATABASE_URL=postgres://user:pass@host:5432/dbname
# POSTGRES_URL=...   # optional alias, same as DATABASE_URL

DB_HOST=localhost
DB_PORT=5432
DB_NAME=worldtrips
DB_USER=postgres
DB_PASSWORD=your_local_db_password_here

JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=30d

FRONTEND_URL=http://localhost:3000

# Optional: comma-separated extra origins (e.g. Vercel preview URLs)
# FRONTEND_URLS=https://worldtrips.vercel.app,https://worldtrips-git-main-xxx.vercel.app

